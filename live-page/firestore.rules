rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // 全コレクション: 読み取りは誰でも可能
    match /{collection}/{docId} {
      allow read: if true;
      // 書き込みは認証済みの運営ユーザーのみ
      allow write: if request.auth != null
                   && request.auth.token.role == 'operator';
    }
  }
}
